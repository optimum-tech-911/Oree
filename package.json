{
  "name": "oree-company-platform",
  "version": "3.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "index:assistant": "node scripts/generate-assistant-index.mjs",
    "brand:optimize": "node scripts/optimize-brand-assets.mjs",
    "images:optimize": "node --experimental-strip-types scripts/optimize-images.ts",
    "predev": "npm run index:assistant",
    "dev": "node scripts/start-dev.mjs",
    "build": "npm run index:assistant && tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build",
    "build:visual": "npm run index:assistant && tsc -b && vite build --config vite.visual.config.ts",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@fontsource-variable/newsreader": "^5.3.0",
    "@fontsource-variable/onest": "^5.3.0",
    "@hookform/resolvers": "5.4.0",
    "@supabase/supabase-js": "2.110.8",
    "@tanstack/react-query": "5.101.4",
    "clsx": "2.1.1",
    "lucide-react": "1.26.0",
    "motion": "12.42.2",
    "react": "19.2.8",
    "react-dom": "19.2.8",
    "react-hook-form": "7.82.0",
    "react-router-dom": "7.18.1",
    "tailwind-merge": "3.6.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "4.3.3",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.4",
    "eslint": "^10.0.1",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.7.0",
    "sharp": "^0.35.3",
    "tailwindcss": "4.3.3",
    "typescript": "7.0.2",
    "typescript-eslint": "8.65.0",
    "vite": "8.1.5",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "4.1.10"
  }
}
